{
  "extends": "../../tsconfig.base.json",
  "include": [
    "env.d.ts",
    "src/**/*",
    "src/**/*.vue",
    "../../packages/is-data-model/src/**/*",
    "../../packages/data-model/src/**/*",
    "../../packages/sdk/src/**/*",
    "../../packages/is-vue-framework/src/**/*",
    "../../packages/utilities/src/**/*"
  ],
  "exclude": [
    "src/**/__tests__/*",
    "../../packages/sdk/src/__tests__/*",
    "../../packages/is-vue-framework/src/**/__tests__/*",
    "../../packages/utilities/src/**/__tests__/*",
    "../../packages/apostle/src/**/__tests__/*"
  ],
  "compilerOptions": {
    "composite": true,
    "baseUrl": ".",
    "moduleSuffixes": [
      ".web",
      ""
    ],
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@southneuhof/is-data-model": [
        "../../packages/is-data-model/src/index.ts"
      ],
      "@southneuhof/is-data-model/*": [
        "../../packages/is-data-model/src/*"
      ],
      "vue3-google-map": [
        "./node_modules/vue3-google-map/dist/types/index.d.ts"
      ],
      "@southneuhof/api": [
        "../api/src/index.ts"
      ],
      "@southneuhof/api/*": [
        "../api/src/*"
      ],
      "@southneuhof/contracts": [
        "../../packages/contracts/src/index.ts"
      ],
      "@southneuhof/contracts/*": [
        "../../packages/contracts/src/*"
      ],
      "@southneuhof/domain": [
        "../../packages/domain/src/index.ts"
      ],
      "@southneuhof/sdk": [
        "../../packages/sdk/src/index.ts"
      ],
      "@southneuhof/sdk/*": [
        "../../packages/sdk/src/*"
      ],
      "@southneuhof/is-vue-framework": [
        "../../packages/is-vue-framework/src/index.ts"
      ],
      "@southneuhof/is-vue-framework/*": [
        "../../packages/is-vue-framework/src/*"
      ],
      "@southneuhof/utilities": [
        "../../packages/utilities/src/index.ts"
      ],
      "@southneuhof/utilities/*": [
        "../../packages/utilities/src/*"
      ],
      "@client/data-model/*": [
        "../../packages/data-model/src/*"
      ],
      "@client/data-model/models/*": [
        "../../packages/data-model/src/models/*"
      ]
    },
    "module": "esnext",
    "target": "es2017"
  },
  "vueCompilerOptions": {
    "strictTemplates": true,
    "checkUnknownProps": false,
    "checkUnknownEvents": false,
    "checkUnknownDirectives": false,
    "checkUnknownComponents": false,
    "checkUnknownSlots": false,
    "checkUnknownAttributes": false
  }
}
