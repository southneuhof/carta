{
  "extends": "./tsconfig.app.json",
  "exclude": [
    "src/**/__tests__/*",
    "../../packages/**/__tests__/**",
    "../../packages/**/*.spec.*",
    "../../packages/**/*.test.*"
  ],
  "compilerOptions": {
    "composite": true,
    "lib": ["DOM", "es2022"],
    "types": ["node", "jsdom"],
    "verbatimModuleSyntax": true,
    "ignoreDeprecations": "5.0"
  }
}
