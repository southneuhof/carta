{
  "extends": "../../tsconfig.base.json",
  "include": [
    "env.d.ts",
    "src/**/*",
    "src/**/*.vue",
    "../../packages/data-model/src/**/*.ts",
    "../../packages/section-schema/src/**/*.ts"
  ],
  "exclude": [
    "src/**/__tests__/*",
    "../../packages/**/__tests__/**",
    "../../packages/**/*.spec.*",
    "../../packages/**/*.test.*"
  ],
  "compilerOptions": {
    "composite": true,
    "moduleSuffixes": [
      ".web",
      ""
    ],
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "vue3-google-map": [
        "./node_modules/vue3-google-map/dist/types/index.d.ts"
      ],
      "@client/data-model": [
        "../../packages/data-model/src/index.ts"
      ],
      "@client/data-model/*": [
        "../../packages/data-model/src/*"
      ],
      "@client/data-model/models/*": [
        "../../packages/data-model/src/models/*"
      ],
      "@client/section-schema": [
        "../../packages/section-schema/src/index.ts"
      ],
      "@client/section-schema/*": [
        "../../packages/section-schema/src/*"
      ]
    },
    "module": "esnext",
    "target": "es2017"
  },
  "vueCompilerOptions": {
    "strictTemplates": true,
    "checkUnknownProps": false,
    "checkUnknownEvents": false,
    "checkUnknownDirectives": false,
    "checkUnknownComponents": true
  }
}
