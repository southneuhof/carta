{
  "extends": "../../tsconfig.workspace-paths.json",
  "include": [
    "env.d.ts",
    "src/**/*",
    "src/**/*.vue",
    "../../packages/apostle/src/**/*.ts",
    "../../packages/data-model/src/**/*.ts",
    "../../packages/is-data-model/src/**/*.ts",
    "../../packages/is-vue-framework/env.d.ts",
    "../../packages/is-vue-framework/src/**/*.ts",
    "../../packages/is-vue-framework/src/**/*.tsx",
    "../../packages/is-vue-framework/src/**/*.vue",
    "../../packages/landing-section-schema/src/**/*.ts",
    "../../packages/landing-sveltekit-framework/src/**/*.ts",
    "../../packages/utilities/src/**/*.ts"
  ],
  "exclude": [
    "src/**/__tests__/*",
    "../../packages/**/__tests__/**",
    "../../packages/**/*.spec.*",
    "../../packages/**/*.test.*"
  ],
  "compilerOptions": {
    "baseUrl": ".",
    "composite": true,
    "moduleSuffixes": [
      ".web",
      ""
    ],
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "vue3-google-map": [
        "./node_modules/vue3-google-map/dist/types/index.d.ts"
      ],
      "@client/data-model": [
        "../../packages/data-model/src/index.ts"
      ],
      "@client/data-model/*": [
        "../../packages/data-model/src/*"
      ],
      "@client/data-model/models/*": [
        "../../packages/data-model/src/models/*"
      ],
      "@southneuhof/apostle": [
        "../../packages/apostle/src/index.ts"
      ],
      "@southneuhof/apostle/*": [
        "../../packages/apostle/src/*"
      ],
      "@southneuhof/is-data-model": [
        "../../packages/is-data-model/src/index.ts"
      ],
      "@southneuhof/is-data-model/*": [
        "../../packages/is-data-model/src/*"
      ],
      "@southneuhof/is-vue-framework": [
        "../../packages/is-vue-framework/src/index.ts"
      ],
      "@southneuhof/is-vue-framework/*": [
        "../../packages/is-vue-framework/src/*"
      ],
      "@southneuhof/landing-sveltekit-framework": [
        "../../packages/landing-sveltekit-framework/src/index.ts"
      ],
      "@southneuhof/landing-sveltekit-framework/*": [
        "../../packages/landing-sveltekit-framework/src/*"
      ],
      "@southneuhof/landing-section-schema": [
        "../../packages/landing-section-schema/src/index.ts"
      ],
      "@southneuhof/landing-section-schema/*": [
        "../../packages/landing-section-schema/src/*"
      ],
      "@southneuhof/utilities": [
        "../../packages/utilities/src/index.ts"
      ],
      "@southneuhof/utilities/*": [
        "../../packages/utilities/src/*"
      ]
    },
    "module": "esnext",
    "target": "es2017"
  },
  "vueCompilerOptions": {
    "strictTemplates": true,
    "checkUnknownProps": false,
    "checkUnknownEvents": false,
    "checkUnknownDirectives": false,
    "checkUnknownComponents": true,
    // "checkUnknownSlots": false,
    // "checkUnknownAttributes": false
  }
}
