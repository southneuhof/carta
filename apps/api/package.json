{
  "name": "@southneuhof/api",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx scripts/dev.ts",
    "rpc:generate": "tsx scripts/generate-rpc.ts",
    "rpc:watch": "tsx watch scripts/generate-rpc.ts",
    "build": "pnpm run rpc:generate && tsc -p tsconfig.json --noEmit",
    "type-check": "pnpm run rpc:generate && tsc -p tsconfig.json --noEmit",
    "test": "node --env-file-if-exists=.env ./node_modules/vitest/vitest.mjs run",
    "db:push": "tsx --env-file-if-exists=.env scripts/push-products.ts",
    "db:reset": "tsx --env-file-if-exists=.env scripts/drop-products.ts && pnpm run db:push",
    "db:smoke": "tsx --env-file-if-exists=.env scripts/smoke-db.ts"
  },
  "exports": {
    ".": "./src/index.ts",
    "./app": "./src/app.ts",
    "./rpc": "./src/rpc.ts"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.6",
    "@hono/zod-validator": "^0.8.0",
    "@southneuhof/sprindle": "workspace:*",
    "drizzle-orm": "1.0.0-rc.4",
    "drizzle-zod": "^0.8.3",
    "hono": "^4.12.27",
    "pg": "^8.22.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/pg": "^8.20.0",
    "drizzle-kit": "1.0.0-rc.4",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "vitest": "^2.1.9"
  }
}
