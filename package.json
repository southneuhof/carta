{
  "name": "base-frontend-monorepo",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@10.8.0",
  "scripts": {
    "dev": "pnpm --filter @southneuhof/framework-web dev",
    "dev:mobile": "pnpm --filter base-mobile start",
    "dev:mobile:legacy": "pnpm --filter base-mobile start",
    "build": "turbo run build",
    "test": "turbo run test --filter=@southneuhof/is-data-model --filter=@southneuhof/apostle --filter=@southneuhof/is-vue-framework --filter=@southneuhof/framework-web",
    "type-check": "turbo run type-check",
    "type-check:mobile": "pnpm --filter base-mobile type-check",
    "lint": "turbo run lint",
    "release:pack": "turbo run build && pnpm --dir packages/model-meta pack && pnpm --dir packages/apostle pack && pnpm --dir packages/vue-framework pack",
    "release:verify": "pnpm release:pack && node scripts/verify-package-contents.mjs",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "publish-packages": "changeset publish",
    "sync:package-repos": "node scripts/sync-package-repos.mjs",
    "sync:package-repos:any": "node scripts/sync-package-repos.mjs --allow-any-branch",
    "sync:package-repos:dry": "node scripts/sync-package-repos.mjs --dry-run --allow-any-branch"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.7",
    "turbo": "^2.0.14",
    "typescript": "^5.9.3",
    "vue-tsc": "^3.2.4"
  }
}
