{
  "name": "base-frontend-monorepo",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@10.8.0",
  "scripts": {
    "dev": "pnpm --filter @southneuhof/framework-web dev",
    "landing:dev": "sh -c 'pnpm run landing:dev:server & pnpm run landing:dev:admin & wait'",
    "landing:dev:server": "pnpm --dir apps/landing-mjl dev -- --port 5173 --strictPort",
    "landing:dev:admin": "pnpm --dir apps/landing-admin-web dev -- --port 5174 --strictPort",
    "dev:mobile": "pnpm --filter base-mobile start",
    "dev:mobile:legacy": "pnpm --filter base-mobile start",
    "build": "turbo run build --filter=@southneuhof/is-data-model --filter=@southneuhof/apostle --filter=@southneuhof/utilities --filter=@southneuhof/is-vue-framework --filter=@southneuhof/landing-section-schema --filter=@southneuhof/landing-sveltekit-framework",
    "test": "turbo run test --filter=@southneuhof/is-data-model --filter=@southneuhof/apostle --filter=@southneuhof/utilities --filter=@southneuhof/is-vue-framework --filter=@southneuhof/landing-section-schema --filter=@southneuhof/landing-sveltekit-framework --filter=@southneuhof/framework-web",
    "type-check": "turbo run type-check --filter=@southneuhof/is-data-model --filter=@southneuhof/apostle --filter=@southneuhof/utilities --filter=@southneuhof/is-vue-framework --filter=@southneuhof/landing-section-schema --filter=@southneuhof/landing-sveltekit-framework",
    "type-check:mobile": "pnpm --filter base-mobile type-check",
    "lint": "turbo run lint",
    "release:build": "node scripts/run-publishable-packages.mjs build",
    "release:test": "node scripts/run-publishable-packages.mjs test",
    "release:type-check": "node scripts/run-publishable-packages.mjs type-check",
    "release:pack": "node scripts/run-publishable-packages.mjs pack",
    "release:verify": "pnpm release:pack && node scripts/verify-package-contents.mjs",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "publish-packages": "changeset publish",
    "sync:package-repos": "node scripts/sync-package-repos.mjs",
    "sync:package-repos:any": "node scripts/sync-package-repos.mjs --allow-any-branch",
    "sync:package-repos:dry": "node scripts/sync-package-repos.mjs --dry-run --allow-any-branch",
    "landing:localize": "node scripts/localize-provider-packages.mjs",
    "landing:check-portable": "node scripts/check-portable-landing.mjs",
    "sync:mjl-landing": "node scripts/sync-mjl-landing.mjs",
    "sync:mjl-landing:dry": "node scripts/sync-mjl-landing.mjs --dry-run"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.7",
    "turbo": "^2.0.14",
    "typescript": "^5.9.3",
    "vue-tsc": "^3.2.4"
  }
}
