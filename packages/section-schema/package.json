{
  "name": "@client/section-schema",
  "private": true,
  "version": "0.0.4",
  "type": "module",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./sections/*": {
      "types": "./src/sections/*.ts",
      "default": "./src/sections/*.ts"
    }
  },
  "dependencies": {
    "@southneuhof/landing-section-schema": "workspace:^",
    "@southneuhof/landing-sveltekit-framework": "workspace:^"
  },
  "scripts": {
    "test": "vitest run",
    "type-check": "tsc --noEmit -p tsconfig.json"
  },
  "devDependencies": {
    "vitest": "^2.1.9",
    "typescript": "^5.9.3",
    "@types/node": "^18.16.16",
    "vite": "^6.0.0"
  }
}
