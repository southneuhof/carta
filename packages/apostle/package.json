{
  "name": "@southneuhof/apostle",
  "private": false,
  "version": "0.0.1",
  "type": "module",
  "description": "HTTP client helpers used by South Neuhof frontend framework packages.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/southneuhof/apostle.git"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "!dist/**/*.tsbuildinfo",
    "!src/**/__tests__/**",
    "!src/**/*.spec.*",
    "!src/**/*.test.*",
    "README.md"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "dependencies": {
    "qs": "^6.11.2"
  },
  "devDependencies": {
    "@types/qs": "^6.9.12",
    "vitest": "^2.1.9"
  },
  "scripts": {
    "build": "pnpm clean && pnpm build:js && pnpm clean:build-info",
    "clean": "node ../../scripts/clean-package.mjs dist",
    "clean:build-info": "node ../../scripts/clean-package.mjs dist/tsconfig.build.tsbuildinfo",
    "build:js": "tsc -p tsconfig.build.json",
    "type-check": "tsc --noEmit -p tsconfig.build.json",
    "test": "vitest run"
  }
}
