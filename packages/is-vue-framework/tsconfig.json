{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "baseUrl": ".",
    "module": "esnext",
    "resolvePackageJsonExports": false,
    "resolvePackageJsonImports": false,
    "paths": {
      "@southneuhof/is-vue-framework": [
        "./src/index.ts"
      ],
      "@southneuhof/is-vue-framework/*": [
        "./src/*"
      ],
      "@southneuhof/is-data-model": [
        "../is-data-model/src/index.ts"
      ],
      "@southneuhof/is-data-model/*": [
        "../is-data-model/src/*"
      ],
      "@southneuhof/apostle": [
        "../apostle/src/index.ts"
      ],
      "@southneuhof/apostle/*": [
        "../apostle/src/*"
      ],
      "@southneuhof/utilities": [
        "../utilities/src/index.ts"
      ],
      "@southneuhof/utilities/*": [
        "../utilities/src/*"
      ]
    }
  },
  "include": [
    "src/**/*",
    "env.d.ts",
    "../apostle/src/**/*",
    "../is-data-model/src/**/*",
    "../utilities/src/**/*"
  ],
  "exclude": [
    "src/**/__tests__/**",
    "src/**/*.spec.*",
    "src/**/*.test.*"
  ],
  "vueCompilerOptions": {
    "strictTemplates": true,
    "checkUnknownProps": false,
    "checkUnknownEvents": false,
    "checkUnknownDirectives": false,
    "checkUnknownComponents": false,
    "checkUnknownSlots": false,
    "checkUnknownAttributes": false
  }
}
