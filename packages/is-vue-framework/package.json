{
  "name": "@southneuhof/is-vue-framework",
  "private": false,
  "version": "1.0.10",
  "type": "module",
  "description": "Vue application framework components and patterns for South Neuhof information systems.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/southneuhof/is-vue-framework.git"
  },
  "exports": {
    ".": "./src/index.ts",
    "./services": "./src/services/index.ts",
    "./adapters/defaults": "./src/adapters/defaults.ts",
    "./adapters/state": "./src/adapters/state.ts",
    "./adapters/behaviors": "./src/adapters/behaviors.ts",
    "./adapters/*": "./src/adapters/*",
    "./components/*": "./src/components/*",
    "./renderers/*": "./src/renderers/*",
    "./behaviors/*": "./src/behaviors/*",
    "./styles/*": "./src/styles/*",
    "./router": "./src/router/index.ts",
    "./router/*": "./src/router/*"
  },
  "peerDependencies": {
    "@southneuhof/is-data-model": "workspace:^",
    "vue": "^3.5.12",
    "vue-router": "^4.2.2"
  },
  "dependencies": {
    "@southneuhof/sdk": "workspace:*",
    "@southneuhof/utilities": "workspace:^",
    "clsx": "^2.1.1",
    "tailwind-merge": "^1.13.1",
    "xlsx": "^0.18.5",
    "vue": "^3.5.12",
    "vue-router": "^4.2.2",
    "vue-sonner": "^2.0.1",
    "@vuepic/vue-datepicker": "^11.0.3",
    "@vueuse/core": "^12.5.0",
    "radix-vue": "^1.9.2",
    "vuedraggable": "^4.1.0",
    "date-fns": "^4.1.0",
    "@tinymce/tinymce-vue": "^6.0.1",
    "tinymce": "^7.2.1",
    "uuid": "^11.0.2",
    "vue3-google-map": "^0.15.0",
    "vue-to-print": "^1.2.1",
    "@headlessui/vue": "^1.7.14",
    "vaul-vue": "^0.3.0",
    "vue-tippy": "^6.7.1"
  },
  "devDependencies": {
    "@types/node": "^18.16.16",
    "@vitejs/plugin-vue": "^5.2.4",
    "jsdom": "^20.0.3",
    "typescript": "^5.9.3",
    "vue-tsc": "^3.2.4",
    "vitest": "^2.1.9"
  },
  "scripts": {
    "build": "pnpm run type-check",
    "type-check": "vue-tsc --noEmit -p tsconfig.json",
    "test": "vitest run --environment jsdom"
  }
}
